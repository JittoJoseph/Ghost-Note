{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ghostnote-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-21",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ghostnote-db",
      "database_id": "local-dev-id",
      "migrations_dir": "drizzle"
    }
  ]
}